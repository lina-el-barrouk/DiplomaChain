# ─── APPLICATION ───────────────────────────────────────────
APP_NAME=DiplomaChain
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── DATABASE (MySQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=diplomachain
DB_USER=diplomachain_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── HEDERA HASHGRAPH ───────────────────────────────────────
HEDERA_NETWORK=testnet                      # testnet | mainnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_PRIVATE_KEY=302e020100300506032b657004220420...
HEDERA_TOPIC_ID=0.0.XXXXXXX               # HCS Topic for diploma anchoring

# ─── REDIS (Rate limiting & Celery) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── EMAIL (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# ─── SECURITY ───────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
MAX_REQUESTS_PER_MINUTE=60
